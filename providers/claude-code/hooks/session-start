#!/usr/bin/env bash
# session-start — Auto-sync skill symlinks on SessionStart

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
ALMANAC_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"

COMMANDS_DIR="$HOME/.claude/commands/almanac"

# Only sync if already installed
if [[ -d "$COMMANDS_DIR" ]]; then
  added=0
  removed=0

  # Add symlinks for new skills
  for dir in "$ALMANAC_ROOT"/skills/*/; do
    [ -f "$dir/SKILL.md" ] || continue
    name=$(basename "$dir")
    target="$COMMANDS_DIR/$name.md"
    if [[ ! -e "$target" && ! -L "$target" ]]; then
      ln -s "$dir/SKILL.md" "$target"
      added=$((added + 1))
    fi
  done

  # Remove dangling symlinks (deleted skills)
  for link in "$COMMANDS_DIR"/*.md; do
    [ -L "$link" ] || continue
    [[ -e "$link" ]] || { rm "$link"; removed=$((removed + 1)); }
  done

  # Sync global CLAUDE.md (only if already ours or missing)
  local_claude_md="$ALMANAC_ROOT/providers/claude-code/CLAUDE.md"
  claude_target="$HOME/.claude/CLAUDE.md"
  if [[ -f "$local_claude_md" ]]; then
    if [[ ! -e "$claude_target" && ! -L "$claude_target" ]]; then
      ln -s "$local_claude_md" "$claude_target"
      added=$((added + 1))
    elif [[ -L "$claude_target" ]] && readlink "$claude_target" | grep -q "almanac"; then
      # Already ours — update if target changed
      current=$(readlink "$claude_target")
      if [[ "$current" != "$local_claude_md" ]]; then
        rm "$claude_target"
        ln -s "$local_claude_md" "$claude_target"
        added=$((added + 1))
      fi
    fi
    # User's own file → leave it alone
  fi

  # Report only if changes were made
  if [[ $added -gt 0 || $removed -gt 0 ]]; then
    msg="almanac: synced"
    [[ $added -gt 0 ]] && msg="$msg, added $added"
    [[ $removed -gt 0 ]] && msg="$msg, removed $removed"
    echo "$msg"
  fi
fi

echo "Success"
