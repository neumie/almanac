#!/usr/bin/env bash
# session-start — Runs on SessionStart to output almanac skill catalog

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
ALMANAC_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"

echo "The following almanac skills are available. Use the Skill tool to invoke them:"
echo ""

for dir in "$ALMANAC_ROOT"/skills/*/; do
  [ -f "$dir/SKILL.md" ] || continue
  name=$(basename "$dir")
  # Extract description from YAML frontmatter
  desc=$(awk '/^---$/{n++; next} n==1 && /^description:/{sub(/^description: */, ""); print; exit}' "$dir/SKILL.md")
  echo "- $name: $desc"
done
